{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2020"],
    "noEmit": true,
    
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "paths": {"@models/*":["../@cds-models/*/index.ts","models/*"]},
    "baseUrl": "./" ,
    "types": ["@sap/cds-compiler","node"]
  },
  "exclude": ["node_modules", "dist", "@cds-models"]
}
